# Mesmo Postgres (Neon) já usado pelo apps/maintenance-backend — este app
# lê/escreve nos mesmos dados (schema "maintenance" + "suite_core" no
# mesmo banco). Não é um banco novo.
DATABASE_URL="postgresql://usuario:senha@host/neondb?sslmode=require&channel_binding=require"
SUITE_CORE_DATABASE_URL="postgresql://usuario:senha@host/neondb?sslmode=require&channel_binding=require"

# NextAuth v4
NEXTAUTH_SECRET="gere com: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"
