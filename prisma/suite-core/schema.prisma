// Cópia local do schema suite_core, mesmo padrão usado em apps/gateway e
// apps/housekeeping (ver comentário lá) — este app é um repositório git
// separado, deployado isoladamente na Vercel, sem acesso ao caminho
// relativo "../../packages/suite-core" que só existe dentro do monorepo
// completo. Só os modelos que este app efetivamente usa (cadastro único de
// usuário + checklist de acesso por módulo) estão copiados aqui. Se o
// schema suite_core mudar, replicar aqui também (e nos outros 3 apps).

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
  output          = "../../generated/suite-core"
}

datasource db {
  provider = "postgresql"
  url      = env("SUITE_CORE_DATABASE_URL")
  schemas  = ["suite_core"]
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  modules TenantModule[]
  events  IntegrationEvent[]
  users   User[]

  @@schema("suite_core")
}

enum SuiteModule {
  BOOKING_REVIEWS
  HOUSEKEEPING
  MAINTENANCE

  @@schema("suite_core")
}

model TenantModule {
  id       String      @id @default(cuid())
  tenantId String
  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  module   SuiteModule
  enabled  Boolean     @default(true)

  apiBaseUrl String?
  apiKeyHash String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, module])
  @@schema("suite_core")
}

model IntegrationEvent {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  sourceModule SuiteModule
  targetModule SuiteModule
  type         String
  payload      Json

  status      EventStatus @default(PENDING)
  attempts    Int         @default(0)
  lastError   String?
  createdAt   DateTime    @default(now())
  processedAt DateTime?

  @@index([tenantId, targetModule, status])
  @@schema("suite_core")
}

enum EventStatus {
  PENDING
  DELIVERED
  FAILED
  SKIPPED_MODULE_DISABLED

  @@schema("suite_core")
}

// Ver comentário completo em packages/suite-core/prisma/schema.prisma.
enum GlobalRole {
  MASTER
  GERENTE
  GOVERNANTA
  CAMAREIRA
  LAVANDERIA
  MANUTENCAO
  ATENDIMENTO

  @@schema("suite_core")
}

model User {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  nome           String
  email          String
  passwordHash   String?
  role           GlobalRole
  telegramChatId String?
  whatsapp       String?
  foto           String?
  ativo          Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  moduleAccess UserModuleAccess[]

  @@unique([tenantId, email])
  @@schema("suite_core")
}

model UserModuleAccess {
  id      String      @id @default(cuid())
  userId  String
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  module  SuiteModule
  enabled Boolean     @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, module])
  @@schema("suite_core")
}
